# =============================================================================
# Roche Scientist Assistant — environment configuration
# Copy this file to `.env` and fill in the values. Never commit your real .env.
# =============================================================================

# --- RAG + triage (Gemini via Google AI Studio) — the only key you need ---
GOOGLE_API_KEY=                       # Free Gemini key at https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-flash-lite-latest # Chat model for grounded answers (large free-tier quota)
EMBEDDING_MODEL=models/gemini-embedding-001  # Gemini embedding model
CHROMA_DB_PATH=./chroma_db            # Where the vector index persists locally

# --- Documents ---
SOPS_PATH=                            # Optional. Defaults to <repo root>/data/sops

# --- Google Drive ---
GOOGLE_DRIVE_FOLDER_ID=             # The ID from your Google Drive folder URL
GOOGLE_SERVICE_ACCOUNT_JSON=        # Path to your service account JSON file

# --- ServiceNow ---
SERVICENOW_INSTANCE_URL=            # e.g. https://devXXXXX.service-now.com
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# --- Behaviour flags ---
MOCK_MODE=true                      # true = use mock ServiceNow responses instead of the live API
CONFIDENCE_THRESHOLD=0.45           # Below this retrieval score, answers are flagged low-confidence

# --- LLM helpers (Groq) — OPTIONAL and currently UNUSED ---
# Sentiment / intent / chat-title / feedback-translation can optionally use Groq.
# This project leaves it blank, so those helpers run on heuristics. Add a free
# key from console.groq.com only if you want to enable them.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
