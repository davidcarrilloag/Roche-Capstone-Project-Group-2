# =============================================================================
# Roche Scientist Assistant — environment configuration
# Copy this file to `.env` and fill in the values. Never commit your real .env.
# =============================================================================

# --- LLM (Groq) — used by sentiment / translator / intent classifier ---
GROQ_API_KEY=                       # Get a free key at console.groq.com — no credit card needed
GROQ_MODEL=llama-3.1-70b-versatile  # Override if Groq rotates model names (see README)

# --- RAG (Gemini via Google AI Studio) — powers document Q&A ---
GOOGLE_API_KEY=                     # Free Gemini key at https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.0-flash       # Chat model for grounded answers
EMBEDDING_MODEL=models/embedding-001  # Gemini embedding model
CHROMA_DB_PATH=./chroma_db          # Where the vector index persists locally

# --- Documents ---
SOPS_PATH=                          # Optional. Defaults to <repo root>/data/sops

# --- Google Drive ---
GOOGLE_DRIVE_FOLDER_ID=             # The ID from your Google Drive folder URL
GOOGLE_SERVICE_ACCOUNT_JSON=        # Path to your service account JSON file

# --- ServiceNow ---
SERVICENOW_INSTANCE_URL=            # e.g. https://devXXXXX.service-now.com
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# --- Behaviour flags ---
MOCK_MODE=true                      # true = use mock ServiceNow responses instead of the live API
CONFIDENCE_THRESHOLD=0.6            # Below this retrieval score, answers are flagged low-confidence
