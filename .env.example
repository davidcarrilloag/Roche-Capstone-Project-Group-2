# =============================================================================
# Roche Scientist Assistant — environment configuration
# Copy this file to `.env` and fill in the values. Never commit your real .env.
# =============================================================================

# --- LLM (Groq) — used by sentiment / translator / intent classifier ---
GROQ_API_KEY=                       # Get a free key at console.groq.com — no credit card needed
GROQ_MODEL=llama-3.1-70b-versatile  # Override if Groq rotates model names (see README)

# --- RAG service (Pablo's pipeline) ---
RAG_SERVICE_URL=http://localhost:8001   # Document Q&A is delegated to Pablo's RAG service

# --- Embeddings / Vector store ---
EMBEDDING_MODEL=all-MiniLM-L6-v2    # Local sentence-transformers model (CPU, no key)
CHROMA_DB_PATH=./chroma_db          # Where Chroma persists vectors locally

# --- Documents ---
MOCK_DOCS_PATH=                     # Optional. Defaults to <repo root>/data/mock_docs

# --- Google Drive ---
GOOGLE_DRIVE_FOLDER_ID=             # The ID from your Google Drive folder URL
GOOGLE_SERVICE_ACCOUNT_JSON=        # Path to your service account JSON file

# --- ServiceNow ---
SERVICENOW_INSTANCE_URL=            # e.g. https://devXXXXX.service-now.com
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# --- Behaviour flags ---
MOCK_MODE=true                      # true = use mock ServiceNow / local docs instead of live APIs
RETRIEVAL_THRESHOLD=0.35            # Below this similarity, RAG returns "not found"
